{
  "name": "blox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "stdb:publish": "spacetime publish blox --server local -y",
    "stdb:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path ./spacetimedb -y"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "ai": "^6.0.197",
    "next": "16.2.7",
    "phaser": "^4.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.21",
    "spacetimedb": "2.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
